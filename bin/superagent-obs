#!/usr/bin/env bash
# superagent-obs — helper bin for hooks to append spans + metrics (Wave 2 §7.3).
# Subcommands:
#   span   --trace <id> --span <id> [--parent <id>] --op <name> --start <ms> --end <ms> --status <OK|ERROR|TIMEOUT> --attrs <json>
#   metric --name <name> --kind <counter|gauge|histogram> --value <num> [--labels <json>] [--ts <iso>]
set -euo pipefail
ROOT="$HOME/.superagent/obs"
SPANS="$ROOT/spans.jsonl"
METRICS="$ROOT/metrics.jsonl"
mkdir -p "$ROOT" 2>/dev/null || true
[[ -f "$SPANS" ]]   || : > "$SPANS"
[[ -f "$METRICS" ]] || : > "$METRICS"

cmd="${1:-}"; shift || true

case "$cmd" in
  -h|--help|"") cat <<EOF
Usage:
  superagent-obs span   --trace <id> --span <id> [--parent <id>] --op <name> --start <ms> --end <ms> --status <OK|ERROR|TIMEOUT> [--attrs <json>]
  superagent-obs metric --name <name> --kind <counter|gauge|histogram> --value <num> [--labels <json>] [--ts <iso>]
EOF
    exit 0 ;;

  span)
    TRACE=""; SPAN=""; PARENT=""; OP=""; START=""; END=""; STATUS="OK"; ATTRS="{}"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --trace)  TRACE="$2"; shift 2 ;;
        --span)   SPAN="$2"; shift 2 ;;
        --parent) PARENT="$2"; shift 2 ;;
        --op)     OP="$2"; shift 2 ;;
        --start)  START="$2"; shift 2 ;;
        --end)    END="$2"; shift 2 ;;
        --status) STATUS="$2"; shift 2 ;;
        --attrs)  ATTRS="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    [[ -z "$TRACE" || -z "$SPAN" || -z "$OP" || -z "$START" || -z "$END" ]] && {
      echo "missing required span flags" >&2; exit 2; }
    PARENT_JSON="null"; [[ -n "$PARENT" ]] && PARENT_JSON="\"$PARENT\""
    jq -nc \
      --arg trace "$TRACE" --arg span "$SPAN" --argjson parent "$PARENT_JSON" \
      --arg op "$OP" --argjson start "$START" --argjson end "$END" \
      --arg status "$STATUS" --argjson attrs "$ATTRS" \
      '{traceId:$trace, spanId:$span, parentSpanId:$parent, op:$op, startMs:$start, endMs:$end, status:$status, attrs:$attrs}' \
      >> "$SPANS"
    ;;

  metric)
    NAME=""; KIND="counter"; VALUE=""; LABELS="{}"; TS=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --name)   NAME="$2"; shift 2 ;;
        --kind)   KIND="$2"; shift 2 ;;
        --value)  VALUE="$2"; shift 2 ;;
        --labels) LABELS="$2"; shift 2 ;;
        --ts)     TS="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    [[ -z "$NAME" || -z "$VALUE" ]] && { echo "missing --name or --value" >&2; exit 2; }
    [[ -z "$TS" ]] && TS=$(date -Iseconds 2>/dev/null || date +%Y-%m-%dT%H:%M:%S%z)
    jq -nc \
      --arg ts "$TS" --arg name "$NAME" --arg kind "$KIND" \
      --argjson value "$VALUE" --argjson labels "$LABELS" \
      '{ts:$ts, name:$name, kind:$kind, value:$value, labels:$labels}' \
      >> "$METRICS"
    ;;

  *)
    echo "unknown subcommand: $cmd" >&2
    exit 2
    ;;
esac
