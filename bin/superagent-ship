#!/usr/bin/env bash
set -euo pipefail
BRANCH=$(git rev-parse --abbrev-ref HEAD)
BASE="${1:-main}"

if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
  echo "ship: refusing to ship $BRANCH" >&2
  exit 1
fi

git fetch origin
git rebase "origin/$BASE"
echo "ship: rebase against origin/$BASE OK"
