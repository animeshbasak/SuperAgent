#!/usr/bin/env bash
# Usage: superagent-cost [today|week|all]
# Reads ~/.superagent/cost/calls.jsonl, groups by model, prints $ cost table + coach note.
set -euo pipefail
RANGE="${1:-today}"
FILE="$HOME/.superagent/cost/calls.jsonl"

if [[ ! -f "$FILE" ]]; then
  echo "no cost data yet (file not found: $FILE)"
  exit 0
fi

python3 - "$FILE" "$RANGE" <<'PY'
import json, sys, datetime, collections
path, rng = sys.argv[1], sys.argv[2]
now = datetime.datetime.now(datetime.timezone.utc)
cutoff = {
  'today': now.replace(hour=0, minute=0, second=0, microsecond=0),
  'week':  now - datetime.timedelta(days=7),
  'all':   datetime.datetime.min.replace(tzinfo=datetime.timezone.utc),
}.get(rng)
if cutoff is None:
  print(f"unknown range: {rng}. use today|week|all", file=sys.stderr)
  sys.exit(2)

PRICE = {'opus': 30, 'sonnet': 6, 'haiku': 1, 'unknown': 10}

agg = collections.Counter()
for line in open(path):
    line = line.strip()
    if not line:
        continue
    try:
        r = json.loads(line)
        t = datetime.datetime.fromisoformat(r['ts'])
        if t < cutoff:
            continue
        m = next((k for k in ('opus','sonnet','haiku') if k in r.get('model','').lower()), 'unknown')
        agg[m] += int(r.get('tokens', 0))
    except Exception:
        continue

if sum(agg.values()) == 0:
    print(f"no records in range: {rng}")
    sys.exit(0)

total = 0.0
print(f"{'model':8} {'tokens':>12}  {'$':>8}")
print('-' * 32)
for m in ('opus', 'sonnet', 'haiku', 'unknown'):
    tok = agg.get(m, 0)
    if tok == 0:
        continue
    cost = tok * PRICE[m] / 1_000_000
    total += cost
    print(f"{m:8} {tok:>12,}  ${cost:>7.2f}")
print('-' * 32)
print(f"{'TOTAL':8} {sum(agg.values()):>12,}  ${total:>7.2f}")

opus = agg.get('opus', 0)
haiku = agg.get('haiku', 0)
if opus > 500_000 and haiku < 100_000:
    print()
    print("Coach: heavy Opus use — try /effort low or Haiku for simple tasks.")
elif opus == 0 and haiku > 1_000_000:
    print()
    print("Coach: all-Haiku — try Sonnet for non-trivial reasoning.")
PY
