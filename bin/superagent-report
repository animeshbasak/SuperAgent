#!/usr/bin/env python3
"""superagent-report — org-pilot before/after report from local telemetry.

Aggregates the data SuperAgent already writes to disk into a one-page
markdown report (or --json) a budget owner can read: spend by model,
measured savings, routing reliability. Only measured numbers — sections
with no underlying data say "no data", never an extrapolated figure.

Usage: superagent-report [--days N] [--project PATH] [--json] [--out FILE]
                         [--org-policy [FILE]]

Sources (all local):
  ~/.superagent/cost/calls.jsonl + pricing.json   spend
  ~/.superagent/brain/routes.jsonl                reliability
  ~/.superagent/brain/optimizations.jsonl         prompt optimization
  ~/.claude/superagent-stats.json                 memory/graph tokens saved
  ~/.superagent/org-policy.json                   org-wide restriction (--org-policy)

With --org-policy the report adds a compliance section: spend vs the org's
budget cap, calls that breached the allowed-model-tier restriction, and — when
the policy sets redact_projects — per-project spend with paths anonymized so
the report can circulate organisation-wide. See bin/superagent-org-policy.
"""
import json
import os
import sys
from datetime import datetime, timedelta, timezone

# Mirrors bin/superagent-cost (2026-Q2 rates, per 1M tokens). Same override file.
DEFAULT_PRICING = {
    "haiku":   {"input": 0.25, "output": 1.25,  "cache_write": 0.30,  "cache_read": 0.03},
    "sonnet":  {"input": 3.00, "output": 15.00, "cache_write": 3.75,  "cache_read": 0.30},
    "opus":    {"input": 15.0, "output": 75.00, "cache_write": 18.75, "cache_read": 1.50},
    "local":   {"input": 0,    "output": 0,     "cache_write": 0,     "cache_read": 0},
    "unknown": {"input": 5.0,  "output": 25.00, "cache_write": 6.25,  "cache_read": 0.50},
}
LOCAL_MARKERS = ("local", "ollama", "llamacpp", "lmstudio", "qwen", "deepseek", "minimax")


def load_org_policy(home):
    """Read ~/.superagent/org-policy.json. Self-contained; mirrors the schema in
    bin/superagent-org-policy (monthly_budget_usd, allowed_model_tiers,
    redact_projects). Returns {} when absent or unparseable."""
    try:
        with open(os.path.join(home, ".superagent", "org-policy.json")) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (OSError, ValueError):
        return {}


def bucket(model_str):
    m = (model_str or "").lower()
    if any(marker in m for marker in LOCAL_MARKERS):
        return "local"
    for k in ("opus", "sonnet", "haiku"):
        if k in m:
            return k
    return "unknown"


def load_pricing(home):
    pricing = {k: dict(v) for k, v in DEFAULT_PRICING.items()}
    path = os.path.join(home, ".superagent", "cost", "pricing.json")
    try:
        with open(path) as f:
            override = json.load(f)
        if isinstance(override, dict):
            for tier, dims in override.items():
                if tier in pricing and isinstance(dims, dict):
                    pricing[tier].update(dims)
    except Exception:
        pass
    return pricing


def iter_jsonl(path):
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    yield json.loads(line)
                except Exception:
                    continue
    except OSError:
        return


def parse_ts(s):
    try:
        dt = datetime.fromisoformat((s or "").replace("Z", "+00:00"))
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt
    except Exception:
        return None


def in_window(rec, cutoff):
    ts = parse_ts(rec.get("ts"))
    return ts is not None and ts >= cutoff


def record_tokens_usd(rec, pricing):
    tier = bucket(rec.get("model", ""))
    p = pricing.get(tier, pricing["unknown"])
    if "input_tokens" in rec:  # v2 schema
        dims = {
            "input": rec.get("input_tokens", 0) or 0,
            "output": rec.get("output_tokens", 0) or 0,
            "cache_write": rec.get("cache_write_tokens", 0) or 0,
            "cache_read": rec.get("cache_read_tokens", 0) or 0,
        }
        tokens = sum(dims.values())
        usd = sum(n * p[d] / 1_000_000 for d, n in dims.items())
    else:  # v1 schema: flat token count, priced at the input rate
        tokens = rec.get("tokens", 0) or 0
        usd = tokens * p["input"] / 1_000_000
    return tier, tokens, usd


def collect(home, days, project, policy=None):
    cutoff = datetime.now(timezone.utc) - timedelta(days=days)
    pricing = load_pricing(home)
    allowed_tiers = (policy or {}).get("allowed_model_tiers") or None

    spend = {"total_tokens": 0, "total_usd": 0.0, "by_model": {}, "by_project": {},
             "calls": 0, "local_calls": 0}
    opus_in = pricing["opus"]["input"]
    counterfactual_usd = 0.0
    offpolicy = {"calls": 0, "usd": 0.0, "tiers": {}}
    for rec in iter_jsonl(os.path.join(home, ".superagent", "cost", "calls.jsonl")):
        if not in_window(rec, cutoff):
            continue
        if project and rec.get("project") not in (project, None):
            continue
        tier, tokens, usd = record_tokens_usd(rec, pricing)
        spend["calls"] += 1
        spend["total_tokens"] += tokens
        spend["total_usd"] += usd
        if tier == "local":
            spend["local_calls"] += 1
        m = spend["by_model"].setdefault(tier, {"tokens": 0, "usd": 0.0})
        m["tokens"] += tokens
        m["usd"] += usd
        proj = rec.get("project") or "(unattributed)"
        pm = spend["by_project"].setdefault(proj, {"tokens": 0, "usd": 0.0})
        pm["tokens"] += tokens
        pm["usd"] += usd
        if allowed_tiers and tier not in allowed_tiers:
            offpolicy["calls"] += 1
            offpolicy["usd"] += usd
            offpolicy["tiers"][tier] = offpolicy["tiers"].get(tier, 0) + 1
        counterfactual_usd += tokens * opus_in / 1_000_000
    spend["counterfactual_opus_usd"] = round(counterfactual_usd, 2)
    spend["total_usd"] = round(spend["total_usd"], 4)
    for m in spend["by_model"].values():
        m["usd"] = round(m["usd"], 4)
    for m in spend["by_project"].values():
        m["usd"] = round(m["usd"], 4)
    offpolicy["usd"] = round(offpolicy["usd"], 4)

    rel = {"routes_total": 0, "routes_done": 0, "routes_fail": 0, "routes_halt": 0,
           "verified_routes": 0, "top_chains": {}}
    for rec in iter_jsonl(os.path.join(home, ".superagent", "brain", "routes.jsonl")):
        if not in_window(rec, cutoff):
            continue
        rel["routes_total"] += 1
        outcome = rec.get("outcome", "")
        if outcome == "done":
            rel["routes_done"] += 1
        elif outcome == "fail":
            rel["routes_fail"] += 1
        elif outcome == "halt":
            rel["routes_halt"] += 1
        chain = rec.get("chain") or []
        if any("verification" in str(s) for s in chain):
            rel["verified_routes"] += 1
        key = " → ".join(chain) if chain else "(none)"
        rel["top_chains"][key] = rel["top_chains"].get(key, 0) + 1
    rel["top_chains"] = dict(sorted(rel["top_chains"].items(), key=lambda kv: -kv[1])[:3])

    sav = {"prompts_seen": 0, "prompts_optimized": 0, "memory_tokens_saved": None}
    for rec in iter_jsonl(os.path.join(home, ".superagent", "brain", "optimizations.jsonl")):
        if not in_window(rec, cutoff):
            continue
        sav["prompts_seen"] += 1
        if rec.get("changed"):
            sav["prompts_optimized"] += 1
    try:
        with open(os.path.join(home, ".claude", "superagent-stats.json")) as f:
            stats = json.load(f)
        projects = stats.get("projects", {})
        items = [projects[project]] if project and project in projects else projects.values()
        total = 0
        found = False
        for p in items:
            lt = p.get("lifetime", {})
            if "total_saved" in lt:
                total += lt.get("total_saved", 0) or 0
                found = True
        if found:
            sav["memory_tokens_saved"] = total
    except Exception:
        pass

    result = {
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "period_days": days,
        "spend": spend,
        "reliability": rel,
        "savings": sav,
    }

    if policy is not None:
        budget = policy.get("monthly_budget_usd")
        active = bool(budget is not None or allowed_tiers or policy.get("redact_projects"))
        compliance = {
            "active": active,
            "budget_usd": budget,
            "spend_usd": spend["total_usd"],
            "over_budget": (budget is not None and spend["total_usd"] > budget),
            "budget_pct": (round(spend["total_usd"] / budget * 100, 1)
                           if budget else None),
            "allowed_model_tiers": allowed_tiers,
            "offpolicy_calls": offpolicy["calls"],
            "offpolicy_usd": offpolicy["usd"],
            "offpolicy_tiers": offpolicy["tiers"],
            "redact_projects": bool(policy.get("redact_projects")),
        }
        compliance["violations"] = int(compliance["over_budget"]) + offpolicy["calls"]
        result["org_policy"] = compliance
        if compliance["redact_projects"]:
            result["spend"]["by_project"] = _redact_projects(spend["by_project"])

    return result


def _redact_projects(by_project):
    """Replace project identifiers with stable project-N aliases (ordered by
    spend, descending) so a report is safe to circulate organisation-wide."""
    ordered = sorted(by_project.items(), key=lambda kv: -kv[1]["usd"])
    return {f"project-{i + 1}": v for i, (_, v) in enumerate(ordered)}


def render_markdown(r):
    s, rel, sav = r["spend"], r["reliability"], r["savings"]
    lines = [
        "# SuperAgent Pilot Report",
        "",
        f"Period: last {r['period_days']} days  ·  Generated: {r['generated_at']}",
        "",
        "## Spend",
        "",
    ]
    if s["calls"] == 0:
        lines.append("no data — cost ledger is empty for this period.")
    else:
        lines.append("| Model tier | Tokens | USD |")
        lines.append("|---|---|---|")
        for tier, m in sorted(s["by_model"].items()):
            lines.append(f"| {tier} | {m['tokens']:,} | ${m['usd']:,.2f} |")
        lines.append(f"| **total** | **{s['total_tokens']:,}** | **${s['total_usd']:,.2f}** |")
        lines.append("")
        lines.append(f"- Calls routed to free local models: {s['local_calls']} of {s['calls']}")
        lines.append(
            f"- Ceiling comparison: same tokens all at Opus input rates would be "
            f"${s['counterfactual_opus_usd']:,.2f} (actual: ${s['total_usd']:,.2f}). "
            f"This is a ceiling, not a savings claim."
        )
    lines += ["", "## Savings (measured)", ""]
    any_sav = False
    if sav["prompts_seen"]:
        any_sav = True
        lines.append(f"- Prompts optimized before dispatch: {sav['prompts_optimized']} of {sav['prompts_seen']}")
    if sav["memory_tokens_saved"] is not None:
        any_sav = True
        lines.append(f"- Tokens saved by memory/graph recall (lifetime): {sav['memory_tokens_saved']:,}")
    if not any_sav:
        lines.append("no data — optimization and memory counters are empty.")
    lines += ["", "## Reliability", ""]
    if rel["routes_total"] == 0:
        lines.append("no data — no routed tasks recorded for this period.")
    else:
        lines.append(
            f"- Routed tasks: {rel['routes_total']} "
            f"(done {rel['routes_done']}, halted {rel['routes_halt']}, failed {rel['routes_fail']})"
        )
        lines.append(f"- Routes that ended in a verification gate: {rel['verified_routes']}")
        if rel["top_chains"]:
            lines.append("- Most-used chains:")
            for chain, n in rel["top_chains"].items():
                lines.append(f"  - {chain} ({n}×)")
    if "org_policy" in r:
        lines += render_org_policy(r)
    lines.append("")
    return "\n".join(lines)


def render_org_policy(r):
    c = r["org_policy"]
    s = r["spend"]
    lines = ["", "## Organisation policy", ""]
    if not c["active"]:
        lines.append(
            "no organisation policy configured — run "
            "`superagent-org-policy set` to define spend/model/visibility restrictions."
        )
        return lines
    if c["violations"] == 0:
        lines.append("Status: ✅ compliant — no policy violations this period.")
    else:
        lines.append(f"Status: ⚠️ {c['violations']} violation(s) this period.")
    lines.append("")
    # Budget restriction
    if c["budget_usd"] is not None:
        if c["over_budget"]:
            over = c["spend_usd"] - c["budget_usd"]
            lines.append(
                f"- Spend cap: ⚠️ OVER BUDGET by ${over:,.2f} — "
                f"spent ${c['spend_usd']:,.2f} of ${c['budget_usd']:,.2f} ({c['budget_pct']}%)."
            )
        else:
            lines.append(
                f"- Spend cap: within budget — ${c['spend_usd']:,.2f} of "
                f"${c['budget_usd']:,.2f} ({c['budget_pct']}% used)."
            )
    else:
        lines.append("- Spend cap: (none set)")
    # Model-tier restriction
    if c["allowed_model_tiers"]:
        allowed = ", ".join(c["allowed_model_tiers"])
        if c["offpolicy_calls"] == 0:
            lines.append(f"- Model tiers: all calls on-policy (allowed: {allowed}).")
        else:
            breakdown = ", ".join(f"{t} ×{n}" for t, n in sorted(c["offpolicy_tiers"].items()))
            lines.append(
                f"- Model tiers: ⚠️ {c['offpolicy_calls']} call(s) off-policy "
                f"({breakdown}) spending ${c['offpolicy_usd']:,.2f}. Allowed: {allowed}."
            )
    else:
        lines.append("- Model tiers: (no restriction)")
    # Visibility restriction (redaction) — surface the per-project table
    if c["redact_projects"]:
        lines.append("- Visibility: project identifiers redacted for org-wide sharing.")
    if s["by_project"]:
        lines += ["", "| Project | Tokens | USD |", "|---|---|---|"]
        for proj, m in sorted(s["by_project"].items(), key=lambda kv: -kv[1]["usd"]):
            lines.append(f"| {proj} | {m['tokens']:,} | ${m['usd']:,.2f} |")
    return lines


def main():
    days = 30
    project = None
    as_json = False
    out_path = None
    org_policy_req = False
    org_policy_file = None
    home = os.path.expanduser("~")
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        a = args[i]
        if a == "--json":
            as_json = True
        elif a == "--days" and i + 1 < len(args):
            i += 1
            try:
                days = int(args[i])
            except ValueError:
                sys.stderr.write("--days expects an integer\n")
                return 1
        elif a == "--project" and i + 1 < len(args):
            i += 1
            project = args[i]
        elif a == "--out" and i + 1 < len(args):
            i += 1
            out_path = args[i]
        elif a == "--org-policy":
            org_policy_req = True
            # Optional FILE argument (skip if the next token is another flag)
            if i + 1 < len(args) and not args[i + 1].startswith("--"):
                i += 1
                org_policy_file = args[i]
        else:
            sys.stderr.write(
                "Usage: superagent-report [--days N] [--project PATH] [--json] "
                "[--out FILE] [--org-policy [FILE]]\n"
            )
            return 1
        i += 1

    policy = None
    if org_policy_req:
        if org_policy_file:
            try:
                with open(org_policy_file) as f:
                    loaded = json.load(f)
                policy = loaded if isinstance(loaded, dict) else {}
            except (OSError, ValueError) as e:
                sys.stderr.write(f"--org-policy: cannot read {org_policy_file}: {e}\n")
                return 1
        else:
            policy = load_org_policy(home)
        if not policy:
            policy = {}  # active but empty → renders an (inactive) policy section

    report = collect(home, days, project, policy)
    body = json.dumps(report, indent=2) if as_json else render_markdown(report)
    if out_path:
        with open(out_path, "w") as f:
            f.write(body + "\n")
    else:
        print(body)
    return 0


if __name__ == "__main__":
    sys.exit(main())
